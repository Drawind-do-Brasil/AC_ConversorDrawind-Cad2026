<Window x:Class="ConversorDrawind.UI.Wpf.Blocks.InventorAttributeFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração"
        Width="800"
        Height="520"
        MinWidth="720"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
            <Button Content="Associar por tags"
                    Width="137"
                    Height="24"
                    Click="AssociateByTagsClick" />
            <Button Content="Associar por ordem"
                    Width="137"
                    Height="24"
                    Margin="6,0,0,0"
                    Click="AssociateByOrderClick" />
            <Button Content="Mover Tags Para Baixo"
                    Width="137"
                    Height="24"
                    Margin="6,0,0,0"
                    Click="MoveTagsDownClick" />
            <Button Content="Mover Tags Para Cima"
                    Width="137"
                    Height="24"
                    Margin="6,0,0,0"
                    Click="MoveTagsUpClick" />
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom"
                    Margin="0,6,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="Cancelar"
                    Width="75"
                    IsCancel="True"
                    Click="CancelClick" />
            <Button Content="Salvar"
                    Width="75"
                    Margin="6,0,0,0"
                    IsDefault="True"
                    Click="SaveClick" />
        </StackPanel>

        <DataGrid x:Name="AssociationGrid"
                  Margin="0,20,0,0"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="False"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  ItemsSource="{Binding Rows}"
                  SelectionMode="Extended"
                  SelectionUnit="Cell"
                  MouseDoubleClick="AssociationGridMouseDoubleClick"
                  MouseRightButtonUp="AssociationGridMouseRightButtonUp">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Blocos Originais"
                                    Binding="{Binding OriginalTag}"
                                    MinWidth="300"
                                    Width="3*" />
                <DataGridTextColumn Header="Blocos CAD"
                                    Binding="{Binding InventorTag}"
                                    MinWidth="300"
                                    Width="3*" />
                <DataGridTextColumn Header="Width Factor"
                                    Binding="{Binding WidthFactor}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
