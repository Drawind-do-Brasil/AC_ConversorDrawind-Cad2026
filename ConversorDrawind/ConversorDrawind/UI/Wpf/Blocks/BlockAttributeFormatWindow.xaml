<Window x:Class="ConversorDrawind.UI.Wpf.Blocks.BlockAttributeFormatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configuração"
        Width="950"
        Height="585"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <Button DockPanel.Dock="Bottom"
                Content="Salvar"
                Width="75"
                Height="24"
                Margin="0,6,0,0"
                HorizontalAlignment="Right"
                IsDefault="True"
                Click="SaveClick" />

        <DataGrid x:Name="TagsGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserSortColumns="False"
                  GridLinesVisibility="All"
                  HeadersVisibility="Column"
                  IsReadOnly="True"
                  ItemsSource="{Binding Rows}"
                  SelectionMode="Extended"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="TagsGridMouseDoubleClick"
                  MouseRightButtonUp="TagsGridMouseRightButtonUp"
                  PreviewMouseLeftButtonUp="TagsGridPreviewMouseLeftButtonUp">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tag"
                                    Binding="{Binding Tag}"
                                    Width="200" />
                <DataGridCheckBoxColumn Header="Modificar"
                                        Binding="{Binding Modify}"
                                        Width="70" />
                <DataGridTextColumn Header="XYZ"
                                    Binding="{Binding Xyz}"
                                    Width="200" />
                <DataGridTextColumn Header="Filtro"
                                    Binding="{Binding Filter}"
                                    Width="300" />
                <DataGridTextColumn Header="Width Factor"
                                    Binding="{Binding WidthFactor}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
