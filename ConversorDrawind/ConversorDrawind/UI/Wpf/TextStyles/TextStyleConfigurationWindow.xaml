<Window x:Class="ConversorDrawind.UI.Wpf.TextStyles.TextStyleConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configura estilos de texto"
        Width="820"
        Height="470"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,15,0,6">
            <Button Content="Incluir linha" Width="168" Height="30" Margin="0,0,6,0" Click="AddButtonClick" />
            <Button Content="Excluir linha" Width="168" Height="30" Click="DeleteButtonClick" />
        </StackPanel>

        <DataGrid x:Name="TextStylesDataGrid"
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="False"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="TextStylesDataGridMouseDoubleClick"
                  VerticalScrollBarVisibility="Auto">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Nome" Binding="{Binding Nome}" Width="150" />
                <DataGridTextColumn Header="Fonte" Binding="{Binding Fonte}" Width="100" />
                <DataGridTextColumn Header="Oblique" Binding="{Binding Oblique}" Width="100" />
                <DataGridTextColumn Header="Negrito" Binding="{Binding Negrito}" Width="100" />
                <DataGridTextColumn Header="Tamanho" Binding="{Binding Tamanho}" Width="100" />
                <DataGridTextColumn Header="Width Factor" Binding="{Binding WidthFactor}" Width="100" />
                <DataGridTextColumn Header="Angulo" Binding="{Binding Angulo}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="Salvar" Width="116" Margin="0,0,6,0" Click="SaveButtonClick" />
            <Button Content="Cancelar" Width="116" IsCancel="True" Click="CancelButtonClick" />
        </StackPanel>
    </Grid>
</Window>
