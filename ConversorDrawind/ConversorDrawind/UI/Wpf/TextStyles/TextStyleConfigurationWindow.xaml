<Window x:Class="ConversorDrawind.UI.Wpf.TextStyles.TextStyleConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TitleTextStylesConfiguration}"
        Width="740"
        Height="420"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <DockPanel Margin="12">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{x:Static local:Localization.ButtonAddLine}" Width="168" Height="30" Margin="0,0,6,0" Click="AddButtonClick" />
            <Button Content="{x:Static local:Localization.ButtonDeleteLine}" Width="168" Height="30" Click="DeleteButtonClick" />
        </StackPanel>

        <DataGrid x:Name="TextStylesDataGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  CanUserResizeColumns="True"
                  CanUserResizeRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  MouseDoubleClick="TextStylesDataGridMouseDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static local:Localization.LabelName}" Binding="{Binding Nome}" Width="150" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelFont}" Binding="{Binding Fonte}" Width="100" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelOblique}" Binding="{Binding Oblique}" Width="100" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelBold}" Binding="{Binding Negrito}" Width="100" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelSize}" Binding="{Binding Tamanho}" Width="100" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelWidthFactor}" Binding="{Binding WidthFactor}" Width="100" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelAngle}" Binding="{Binding Angulo}" Width="100" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="{x:Static local:Localization.ButtonSave}" Width="116" Margin="0,0,6,0" Click="SaveButtonClick" />
            <Button Content="{x:Static local:Localization.ButtonCancel}" Width="116" IsCancel="True" Click="CancelButtonClick" />
        </StackPanel>
    </DockPanel>
</Window>
