<Window x:Class="ConversorDrawind.UI.Wpf.TextStyles.TextStyleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Novo Estilo de Texto"
        Width="520"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86" />
                <ColumnDefinition Width="190" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Nome:" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="NameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" />
            <StackPanel Grid.Row="0" Grid.Column="2" Margin="32,0,0,8">
                <CheckBox x:Name="ObliqueCheckBox" Content="Oblique" Margin="0,0,0,4" />
                <CheckBox x:Name="BoldCheckBox" Content="Negrito" />
            </StackPanel>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Fonte:" VerticalAlignment="Center" Margin="0,0,8,8" />
            <ComboBox x:Name="FontComboBox"
                      Grid.Row="1"
                      Grid.Column="1"
                      IsEditable="False"
                      IsTextSearchEnabled="True"
                      Margin="0,0,0,8"
                      SelectionChanged="FontComboBoxSelectionChanged" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Tamanho:" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="SizeTextBox"
                     Grid.Row="2"
                     Grid.Column="1"
                     Width="110"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,8"
                     PreviewTextInput="DecimalTextBoxPreviewTextInput"
                     LostFocus="SizeTextBoxLostFocus" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="Width Factor:" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="WidthFactorTextBox"
                     Grid.Row="3"
                     Grid.Column="1"
                     Width="110"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,8"
                     PreviewTextInput="DecimalTextBoxPreviewTextInput"
                     LostFocus="WidthFactorTextBoxLostFocus" />

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Angulo:" VerticalAlignment="Center" Margin="0,0,8,16" />
            <TextBox x:Name="AngleTextBox"
                     Grid.Row="4"
                     Grid.Column="1"
                     Width="110"
                     HorizontalAlignment="Left"
                     Margin="0,0,0,16"
                     PreviewTextInput="AngleTextBoxPreviewTextInput"
                     LostFocus="AngleTextBoxLostFocus" />

            <StackPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Salvar" IsDefault="True" MinWidth="96" Margin="0,0,8,0" Click="SaveButtonClick" />
                <Button Content="Cancelar" IsCancel="True" MinWidth="96" Click="CancelButtonClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
