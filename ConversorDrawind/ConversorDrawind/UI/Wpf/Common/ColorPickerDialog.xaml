<Window x:Class="ConversorDrawind.UI.Wpf.Common.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TitleColorRgb}"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="64" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static local:Localization.LabelRed}" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="RedTextBox" Grid.Row="0" Grid.Column="1" MaxLength="3" Margin="0,0,0,8" PreviewTextInput="ColorComponentPreviewTextInput" TextChanged="ColorComponentTextChanged" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static local:Localization.LabelGreen}" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="GreenTextBox" Grid.Row="1" Grid.Column="1" MaxLength="3" Margin="0,0,0,8" PreviewTextInput="ColorComponentPreviewTextInput" TextChanged="ColorComponentTextChanged" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="{x:Static local:Localization.LabelBlue}" VerticalAlignment="Center" Margin="0,0,8,8" />
            <TextBox x:Name="BlueTextBox" Grid.Row="2" Grid.Column="1" MaxLength="3" Margin="0,0,0,8" PreviewTextInput="ColorComponentPreviewTextInput" TextChanged="ColorComponentTextChanged" />

            <TextBlock Grid.Row="3" Grid.Column="0" Text="{x:Static local:Localization.LabelRgbColor}" VerticalAlignment="Center" Margin="0,0,8,16" />
            <TextBox x:Name="ColorTextBox" Grid.Row="3" Grid.Column="1" IsReadOnly="True" Margin="0,0,0,16" />

            <StackPanel Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static local:Localization.ButtonContinue}" IsDefault="True" MinWidth="96" Margin="0,0,8,0" Click="ContinueButtonClick" />
                <Button Content="{x:Static local:Localization.ButtonCancel}" IsCancel="True" MinWidth="96" Click="CancelButtonClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
