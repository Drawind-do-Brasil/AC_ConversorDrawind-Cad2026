<Window x:Class="ConversorDrawind.UI.Wpf.Configuration.AdvancedConfigurationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TitleConfigurationAdvanced}"
        Width="300"
        Height="180"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid>
        <Button Content="{x:Static local:Localization.ButtonOk}"
                Width="75"
                Height="24"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                Margin="0,0,12,12"
                IsDefault="True"
                Click="OkClick" />
    </Grid>
</Window>
