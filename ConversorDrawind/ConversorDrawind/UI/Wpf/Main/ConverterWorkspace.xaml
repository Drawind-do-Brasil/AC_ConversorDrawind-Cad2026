<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<Grid Margin="10" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"><Grid.ColumnDefinitions><ColumnDefinition Width="2*" /><ColumnDefinition Width="2*" /><ColumnDefinition Width="170" /></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions><StackPanel Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,0,0,8"><Button Content="Adicionar arquivos" Width="140" Click="AddDrawingsClick" /><Button Content="Limpar lista" Width="100" Margin="8,0,0,0" Click="ClearDrawingsClick" /><Button Content="Restaurar últimos arquivos convertidos" Width="220" Margin="8,0,0,0" Click="RestoreLastConvertedClick" /><CheckBox x:Name="KeepFilesOpenCheckBox" Content="Manter os arquivos abertos" Margin="18,4,0,0" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /><TextBlock Text="Extensão:" Margin="18,4,4,0" /><ComboBox x:Name="ExtensionComboBox" Width="78" IsEditable="True" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /><TextBlock Text="Status:" Margin="18,4,4,0" /><ComboBox x:Name="StatusComboBox" Width="150" DisplayMemberPath="Nome" SelectionChanged="StatusComboBoxSelectionChanged" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /></StackPanel><GroupBox Grid.Row="1" Grid.Column="0" Header="Desenhos" Margin="0,0,8,0"><ListBox x:Name="DrawingsListBox" AllowDrop="True" Drop="DrawingsDrop" DragEnter="DrawingsDragEnter" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /></GroupBox><GroupBox Grid.Row="1" Grid.Column="1" Header="Conversores" Margin="0,0,8,0"><ListBox x:Name="ConvertersListBox" SelectionChanged="ConvertersSelectionChanged" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /></GroupBox><Button Grid.Row="1" Grid.Column="2" Content="Converter" Height="44" VerticalAlignment="Top" Click="ConvertClick" /><TextBlock Grid.Row="2" Grid.ColumnSpan="3" Text="Comentários" Margin="0,8,0,2" /><TextBox Grid.Row="3" Grid.ColumnSpan="3" x:Name="TemplateCommentsTextBox" Height="62" AcceptsReturn="True" TextWrapping="Wrap" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /></Grid>
</UserControl>
