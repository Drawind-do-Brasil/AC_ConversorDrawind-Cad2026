<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorLayersAndStylesTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <StackPanel Margin="10">
        <Button Content="{x:Static local:Localization.ButtonLoadClientLayers}" Width="210" Click="LoadClientLayersClick" />
        <Separator Visibility="Hidden" Margin="2.5"/>
        <Button Content="{x:Static local:Localization.ButtonConfigureClientLayers}" Width="210" Click="ConfigureClientLayersClick" />
        <Separator Visibility="Hidden" Margin="2.5"/>
        <Button Content="{x:Static local:Localization.ButtonConfigureTextStyles}" Width="210" Click="ConfigureTextStylesClick" />
    </StackPanel>
</UserControl>
