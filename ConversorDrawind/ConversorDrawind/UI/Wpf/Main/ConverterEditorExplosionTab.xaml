<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorExplosionTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition />
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel>
            <TextBlock Text="{x:Static local:Localization.LabelAllLayers}" />
            <ListBox x:Name="AllExplodeLayersListBox" Height="420" />
            <Separator Visibility="Hidden" Margin="2.5"/>

        </StackPanel>
        <Grid  Grid.Column="1" VerticalAlignment="Center" Margin="5">
            <StackPanel>
                <Button Content="{x:Static local:Localization.ButtonAdd}" Click="AddExplodeLayerClick" />
                <Separator Visibility="Hidden" Margin="2.5"/>
                <Button Content="{x:Static local:Localization.ButtonRemove}" Click="RemoveExplodeLayerClick" />
            </StackPanel>
        </Grid>
        <StackPanel Grid.Column="2">
            <TextBlock Text="{x:Static local:Localization.LabelExplodeOnlyLayers}" />
            <ListBox x:Name="SelectedExplodeLayersListBox" Height="420" />
            <Separator Visibility="Hidden" Margin="2.5"/>
          
        </StackPanel>
    </Grid>
</UserControl>
