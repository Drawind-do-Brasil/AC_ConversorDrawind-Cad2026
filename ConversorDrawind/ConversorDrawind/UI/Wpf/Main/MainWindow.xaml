<Window x:Class="ConversorDrawind.UI.Wpf.Main.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        xmlns:main="clr-namespace:ConversorDrawind.UI.Wpf.Main"
        xmlns:viewModels="clr-namespace:ConversorDrawind.UI.Wpf.Main.ViewModels"
        Title="{x:Static local:Localization.AppMainWindowTitle}"
        Width="1050"
        Height="760"
        MinWidth="980"
        MinHeight="680"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <viewModels:SourceModeToBooleanConverter x:Key="SourceModeToBooleanConverter" />
        <viewModels:InverseBooleanConverter x:Key="InverseBooleanConverter" />
    </Window.Resources>
    <DockPanel Margin="10">
        <Grid DockPanel.Dock="Bottom" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Foreground="Blue" VerticalAlignment="Center" Text="{x:Static local:Localization.AppCompatibilityText}" />
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBlock Margin="0,0,18,0" VerticalAlignment="Center" Text="{x:Static local:Localization.AppDevelopedByText}" />
                <TextBlock VerticalAlignment="Center" Text="{x:Static local:Localization.AppCopyrightText}" />
            </StackPanel>
        </Grid>

        <TabControl x:Name="MainTabs">
            <TabItem Header="{x:Static local:Localization.TabConverter}">
                <main:ConverterWorkspace x:Name="ConverterView" />
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabCreateConverter}">
                <main:ConverterEditorWorkspace x:Name="EditorView" />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
