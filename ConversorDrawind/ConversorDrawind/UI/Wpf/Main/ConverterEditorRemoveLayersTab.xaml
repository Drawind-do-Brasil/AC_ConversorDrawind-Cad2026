<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorRemoveLayersTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Left" Width="230" Margin="0,0,10,0">
            <TextBlock Text="{x:Static local:Localization.LabelLayersAfterConversion}" />
            <ListBox x:Name="RemoveLayerBaseListBox" Height="320" SelectionMode="Extended" />
            <Button Content="{x:Static local:Localization.ButtonAdd}" Margin="0,8,0,0" Click="AddRemoveLayerClick" />
            <Button Content="{x:Static local:Localization.ButtonRemove}" Margin="0,6,0,0" Click="DeleteRemoveLayerClick" />
        </StackPanel>
        <DataGrid x:Name="RemoveLayersGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended" MouseDoubleClick="RemoveLayersGridDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayer}" Binding="{Binding Layer}" Width="220" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerFilter}" Binding="{Binding Filter}" Width="360" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
