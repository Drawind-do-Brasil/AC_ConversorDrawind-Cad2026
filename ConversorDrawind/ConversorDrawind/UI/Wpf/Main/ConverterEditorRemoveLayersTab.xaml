<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorRemoveLayersTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <DockPanel Margin="10">
        <Grid Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{x:Static local:Localization.LabelLayersAfterConversion}" />
            <ListBox Grid.Row="1"  x:Name="RemoveLayerBaseListBox"  SelectionMode="Extended" Margin="0,0,0,10" />
            
            <StackPanel  Grid.Row="2" DockPanel.Dock="Left" Width="230">
           
                <Button Content="{x:Static local:Localization.ButtonAdd}"  Click="AddRemoveLayerClick" />
                <Separator Visibility="Hidden" Margin="2.5"/>
                <Button Content="{x:Static local:Localization.ButtonRemove}"  Click="DeleteRemoveLayerClick" />
            </StackPanel>
        </Grid>
        <DataGrid x:Name="RemoveLayersGrid"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Extended"
                  MouseDoubleClick="RemoveLayersGridDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayer}" Binding="{Binding Layer}" Width="220" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerFilter}" Binding="{Binding Filter}" Width="360" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
