<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
<DockPanel Margin="10" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8"><Button Content="Novo" Width="90" Click="NewConverterClick" /><Button Content="Salvar" Width="90" Margin="6,0,0,0" Click="SaveConverterClick" /><Button Content="Importar" Width="90" Margin="6,0,0,0" Click="ImportConverterClick" /><TextBlock Text="Nome:" Margin="18,4,4,0" /><TextBox x:Name="ConverterNameTextBox" Width="260" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /><TextBlock Text="Template:" Margin="18,4,4,0" /><ComboBox x:Name="ConverterComboBox" Width="220" SelectionChanged="ConverterComboBoxSelectionChanged" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" /></StackPanel><TabControl x:Name="ConfigurationTabs" SelectionChanged="ConfigurationTabsSelectionChanged" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"><TabItem Header="Principal"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10"><CheckBox x:Name="ConvertDimensionsCheckBox" Content="Converter cotas" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" /><CheckBox x:Name="ConvertLayersCheckBox" Content="Converter e ou remover layers" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" /><CheckBox x:Name="ScaleDrawingCheckBox" Content="Colocar o desenho na escala real" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" /><CheckBox x:Name="AttributeFormatCheckBox" Content="Atributar o formato do desenho" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" /><CheckBox x:Name="RunCommandsCheckBox" Content="Executar comandos no final" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" /><CheckBox x:Name="ShowErrorMessagesCheckBox" Content="Habilitar mensagens de erro caso ocorram" /><CheckBox x:Name="DeleteTeklaCheckBox" Content="Deletar a palavra Tekla structures do desenho" /><CheckBox x:Name="PurgeCheckBox" Content="Purgar o desenho" /><CheckBox x:Name="ExplodeCheckBox" Content="Explodir" /><CheckBox x:Name="ExplodeBlocksCheckBox" Content="Explodir Blocos" /><CheckBox x:Name="DmBlockCheckBox" Content="Adicionar bloco do DM" /><GroupBox Header="Origem dos desenhos" Margin="0,12,0,0"><StackPanel><RadioButton x:Name="TeklaOriginRadio" Content="Tekla Structures" Checked="OriginChanged" /><RadioButton x:Name="CadOriginRadio" Content="CAD" Checked="OriginChanged" /></StackPanel></GroupBox><TextBlock Text="Comentário" Margin="0,12,0,2" /><TextBox x:Name="AddCommentsTextBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" /></StackPanel></ScrollViewer></TabItem><TabItem Header="Layers e Estilos"><StackPanel Margin="10"><Button Content="Carregar layers do cliente" Width="210" Click="LoadClientLayersClick" /><Button Content="Configurar layers do cliente" Width="210" Margin="0,8,0,0" Click="ConfigureClientLayersClick" /><Button Content="Configurar estilos de texto" Width="210" Margin="0,8,0,0" Click="ConfigureTextStylesClick" /></StackPanel></TabItem><TabItem Header="Conversores"><DockPanel Margin="10"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8"><Button Content="Incluir linha" Width="110" Click="AddLayerRuleClick" /><Button Content="Excluir linhas" Width="110" Margin="6,0,0,0" Click="DeleteLayerRuleClick" /><Button Content="Mover para cima" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleUpClick" /><Button Content="Mover para baixo" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleDownClick" /><TextBlock Text="Ltscale:" Margin="18,4,4,0" /><TextBox x:Name="LtScaleTextBox" Width="70" /><TextBlock Text="Layer texto Tekla:" Margin="18,4,4,0" /><ComboBox x:Name="TeklaTextLayerComboBox" Width="150" /><TextBlock Text="Layer formato:" Margin="18,4,4,0" /><ComboBox x:Name="FormatBlockLayerComboBox" Width="150" /></StackPanel><DataGrid x:Name="LayerRulesGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended" MouseDoubleClick="LayerRulesGridDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="Layer Base" Binding="{Binding BaseLayer}" Width="220" /><DataGridTextColumn Header="Filtro" Binding="{Binding Filter}" Width="320" /><DataGridTextColumn Header="Novo Layer" Binding="{Binding NewLayer}" Width="320" /></DataGrid.Columns></DataGrid></DockPanel></TabItem><TabItem Header="Dimensões"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="10"><UniformGrid Columns="4"><TextBlock Text="Layer" /><ComboBox x:Name="DimensionLayerComboBox" IsEditable="True" /><TextBlock Text="Cor da linha" /><ComboBox x:Name="DimensionLineColorComboBox" IsEditable="True" /><TextBlock Text="Cor do texto" /><ComboBox x:Name="DimensionTextColorComboBox" IsEditable="True" /><TextBlock Text="Tipo de seta" /><ComboBox x:Name="DimensionArrowTypeComboBox" IsEditable="True" /><TextBlock Text="DimStyle" /><TextBox x:Name="DimensionStyleTextBox" /><TextBlock Text="Estilo de Texto" /><ComboBox x:Name="TextStyleComboBox" IsEditable="True" /><TextBlock Text="Dimension scale" /><TextBox x:Name="DimensionScaleTextBox" /><TextBlock Text="Dimension arrow size" /><TextBox x:Name="DimensionArrowSizeTextBox" /><TextBlock Text="Dimension offset" /><TextBox x:Name="DimensionOffsetTextBox" /><TextBlock Text="Line extend" /><TextBox x:Name="DimensionLineExtTextBox" /><TextBlock Text="Linear precision" /><ComboBox x:Name="DimensionLinearPrecisionComboBox" /><TextBlock Text="Angular precision" /><ComboBox x:Name="DimensionAngularPrecisionComboBox" /><TextBlock Text="Linear unit" /><ComboBox x:Name="DimensionLinearUnitComboBox" /><TextBlock Text="Angular unit" /><ComboBox x:Name="DimensionAngularUnitComboBox" /><TextBlock Text="Outside align" /><ComboBox x:Name="DimensionOutsideAlignComboBox" /><TextBlock Text="Line forced" /><ComboBox x:Name="DimensionLineForcedComboBox" /><TextBlock Text="Text inside" /><ComboBox x:Name="DimensionTextInsideComboBox" /><TextBlock Text="Text alignment" /><ComboBox x:Name="DimensionTextAlignmentComboBox" /><TextBlock Text="Text placement vertical" /><ComboBox x:Name="DimensionTextPlacementComboBox" /><TextBlock Text="Layer base" /><ComboBox x:Name="DimensionBaseLayerComboBox" IsEditable="True" /></UniformGrid><Button Content="Configurações Avançadas de Seta" Width="260" Margin="0,12,0,0" Click="DimensionArrowAdvancedClick" /></StackPanel></ScrollViewer></TabItem><TabItem Header="Escala"><StackPanel Margin="10"><RadioButton x:Name="ManualScaleRadio" Content="Escala manual" Checked="ScaleModeChanged" /><RadioButton x:Name="AutoScaleRadio" Content="Escala automática" Checked="ScaleModeChanged" /><GroupBox Header="Manual" Margin="0,10,0,0"><UniformGrid Columns="6"><TextBlock Text="P1 X" /><TextBox x:Name="P1XTextBox" /><TextBlock Text="P1 Y" /><TextBox x:Name="P1YTextBox" /><TextBlock Text="P1 Z" /><TextBox x:Name="P1ZTextBox" /><TextBlock Text="P2 X" /><TextBox x:Name="P2XTextBox" /><TextBlock Text="P2 Y" /><TextBox x:Name="P2YTextBox" /><TextBlock Text="P2 Z" /><TextBox x:Name="P2ZTextBox" /></UniformGrid></GroupBox><GroupBox Header="Automática" Margin="0,10,0,0"><UniformGrid Columns="6"><TextBlock Text="P1 X" /><TextBox x:Name="AP1XTextBox" /><TextBlock Text="P1 Y" /><TextBox x:Name="AP1YTextBox" /><TextBlock Text="P1 Z" /><TextBox x:Name="AP1ZTextBox" /><TextBlock Text="P2 X" /><TextBox x:Name="AP2XTextBox" /><TextBlock Text="P2 Y" /><TextBox x:Name="AP2YTextBox" /><TextBlock Text="P2 Z" /><TextBox x:Name="AP2ZTextBox" /><TextBlock Text="Layer texto" /><ComboBox x:Name="ZoomLayerFilterComboBox" IsEditable="True" /><TextBlock Text="Tamanho texto" /><TextBox x:Name="ZoomTextSizeTextBox" /></UniformGrid></GroupBox></StackPanel></TabItem><TabItem Header="Remoção de Layers"><DockPanel Margin="10"><StackPanel DockPanel.Dock="Left" Width="230" Margin="0,0,10,0"><TextBlock Text="Layers depois de convertido" /><ListBox x:Name="RemoveLayerBaseListBox" Height="320" /><Button Content="Adicionar" Margin="0,8,0,0" Click="AddRemoveLayerClick" /><Button Content="Remover" Margin="0,6,0,0" Click="DeleteRemoveLayerClick" /></StackPanel><DataGrid x:Name="RemoveLayersGrid" AutoGenerateColumns="False" CanUserAddRows="False" MouseDoubleClick="RemoveLayersGridDoubleClick"><DataGrid.Columns><DataGridTextColumn Header="Layer" Binding="{Binding Layer}" Width="220" /><DataGridTextColumn Header="Filtro" Binding="{Binding Filter}" Width="360" /></DataGrid.Columns></DataGrid></DockPanel></TabItem><TabItem Header="Blocos e Atributos"><TabControl Margin="10"><TabItem Header="Tekla Structures"><DockPanel Margin="8"><StackPanel DockPanel.Dock="Top" Orientation="Horizontal"><TextBox x:Name="AttributedFormatPathTextBox" Width="520" /><Button Content="Formato Atributado" Margin="6,0,0,0" Click="BrowseAttributedFormatClick" /></StackPanel><ListBox x:Name="BlocksListBox" Margin="0,8,0,0" /><StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right"><Button Content="Editar" Click="EditBlockClick" /><Button Content="Remover" Margin="6,0,0,0" Click="RemoveBlockClick" /></StackPanel></DockPanel></TabItem><TabItem Header="CAD"><Grid Margin="8"><Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions><StackPanel Grid.Column="0"><TextBlock Text="CAD" /><ListBox x:Name="InventorBlocksListBox" Height="320" /><Button Content="Carregar blocos do CAD" Click="LoadInventorBlocksClick" /></StackPanel><StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="Originais" /><ListBox x:Name="OriginalBlocksListBox" Height="320" /><Button Content="Carregar blocos originais" Click="LoadOriginalBlocksClick" /></StackPanel><StackPanel Grid.Column="2"><TextBlock Text="Relações" /><ListBox x:Name="BlockRelationsListBox" Height="320" MouseDoubleClick="BlockRelationsDoubleClick" /><Button Content="Relacionar" Click="RelateBlocksClick" /><Button Content="Editar parâmetros da relação" Margin="0,6,0,0" Click="EditBlockRelationClick" /><Button Content="Remover relação" Margin="0,6,0,0" Click="RemoveBlockRelationClick" /></StackPanel></Grid></TabItem></TabControl></TabItem><TabItem Header="Configuração de LISP/DLL"><Grid Margin="10"><Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions><GroupBox Header="LISP" Margin="0,0,5,0"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBox x:Name="LispCommandTextBox" /><TextBox x:Name="LispPathTextBox" Margin="0,4,0,0" /><CheckBox x:Name="RunOnlyAtEndCheckBox" Content="Executar somente no final" /><Button Content="Adicionar" Click="AddLispClick" /></StackPanel><ListBox x:Name="LispListBox" /></DockPanel></GroupBox><GroupBox Grid.Column="1" Header="DLL" Margin="5,0,0,0"><DockPanel><StackPanel DockPanel.Dock="Top"><TextBox x:Name="DllCommandTextBox" /><TextBox x:Name="DllPathTextBox" Margin="0,4,0,0" /><Button Content="Salvar" Click="AddDllClick" /></StackPanel><ListBox x:Name="DllListBox" /></DockPanel></GroupBox></Grid></TabItem><TabItem Header="Explosão de Blocos"><Grid Margin="10"><Grid.ColumnDefinitions><ColumnDefinition /><ColumnDefinition /></Grid.ColumnDefinitions><StackPanel><TextBlock Text="Todos os layers" /><ListBox x:Name="AllExplodeLayersListBox" Height="420" /><Button Content="Adicionar" Click="AddExplodeLayerClick" /></StackPanel><StackPanel Grid.Column="1" Margin="10,0,0,0"><TextBlock Text="Explodir somente blocos nos layers" /><ListBox x:Name="SelectedExplodeLayersListBox" Height="420" /><Button Content="Remover" Click="RemoveExplodeLayerClick" /></StackPanel></Grid></TabItem></TabControl></DockPanel>
</UserControl>
