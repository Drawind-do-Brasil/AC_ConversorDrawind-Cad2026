<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorWorkspace"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{x:Static local:Localization.ButtonNew}" Width="90" Click="NewConverterClick" />
            <Button Content="{x:Static local:Localization.ButtonSave}" Width="90" Margin="6,0,0,0" Click="SaveConverterClick" />
            <Button Content="{x:Static local:Localization.ButtonImport}" Width="90" Margin="6,0,0,0" Click="ImportConverterClick" />
            <TextBlock Text="{x:Static local:Localization.LabelName}" Margin="18,4,4,0" />
            <TextBox x:Name="ConverterNameTextBox" Width="260" />
            <TextBlock Text="{x:Static local:Localization.LabelTemplate}" Margin="18,4,4,0" />
            <ComboBox x:Name="ConverterComboBox" Width="220" SelectionChanged="ConverterComboBoxSelectionChanged" />
        </StackPanel>
        <TabControl x:Name="ConfigurationTabs" SelectionChanged="ConfigurationTabsSelectionChanged">
            <TabItem Header="{x:Static local:Localization.TabMain}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <CheckBox x:Name="ConvertDimensionsCheckBox" Content="{x:Static local:Localization.LabelConvertDimensions}" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" />
                        <CheckBox x:Name="ConvertLayersCheckBox" Content="{x:Static local:Localization.LabelConvertLayers}" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" />
                        <CheckBox x:Name="ScaleDrawingCheckBox" Content="{x:Static local:Localization.LabelScaleDrawing}" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" />
                        <CheckBox x:Name="AttributeFormatCheckBox" Content="{x:Static local:Localization.LabelAttributeDrawingFormat}" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" />
                        <CheckBox x:Name="RunCommandsCheckBox" Content="{x:Static local:Localization.LabelRunCommandsAtEnd}" Checked="FeatureCheckChanged" Unchecked="FeatureCheckChanged" />
                        <CheckBox x:Name="ShowErrorMessagesCheckBox" Content="{x:Static local:Localization.LabelEnableErrorMessages}" />
                        <CheckBox x:Name="DeleteTeklaCheckBox" Content="{x:Static local:Localization.LabelDeleteTeklaWord}" />
                        <CheckBox x:Name="PurgeCheckBox" Content="{x:Static local:Localization.LabelPurgeDrawing}" />
                        <CheckBox x:Name="ExplodeCheckBox" Content="{x:Static local:Localization.LabelExplode}" />
                        <CheckBox x:Name="ExplodeBlocksCheckBox" Content="{x:Static local:Localization.LabelExplodeBlocks}" />
                        <CheckBox x:Name="DmBlockCheckBox" Content="{x:Static local:Localization.LabelAddDmBlock}" />
                        <GroupBox Header="{x:Static local:Localization.LabelOriginOfDrawings}" Margin="0,12,0,0">
                            <StackPanel>
                                <RadioButton x:Name="TeklaOriginRadio" Content="{x:Static local:Localization.LabelTeklaStructures}" Checked="OriginChanged" />
                                <RadioButton x:Name="CadOriginRadio" Content="{x:Static local:Localization.LabelCad}" Checked="OriginChanged" />
                            </StackPanel>
                        </GroupBox>
                        <TextBlock Text="{x:Static local:Localization.LabelComments}" Margin="0,12,0,2" />
                        <TextBox x:Name="AddCommentsTextBox" Height="70" AcceptsReturn="True" TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabLayersAndStyles}">
                <StackPanel Margin="10">
                    <Button Content="{x:Static local:Localization.ButtonLoadClientLayers}" Width="210" Click="LoadClientLayersClick" />
                    <Button Content="{x:Static local:Localization.ButtonConfigureClientLayers}" Width="210" Margin="0,8,0,0" Click="ConfigureClientLayersClick" />
                    <Button Content="{x:Static local:Localization.ButtonConfigureTextStyles}" Width="210" Margin="0,8,0,0" Click="ConfigureTextStylesClick" />
                </StackPanel>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabConverters}">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="{x:Static local:Localization.ButtonAdd}" Width="110" Click="AddLayerRuleClick" />
                        <Button Content="{x:Static local:Localization.ButtonDelete}" Width="110" Margin="6,0,0,0" Click="DeleteLayerRuleClick" />
                        <Button Content="{x:Static local:Localization.ButtonMoveUp}" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleUpClick" />
                        <Button Content="{x:Static local:Localization.ButtonMoveDown}" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleDownClick" />
                        <TextBlock Text="{x:Static local:Localization.LabelLtScale}" Margin="18,4,4,0" />
                        <TextBox x:Name="LtScaleTextBox" Width="70" />
                        <TextBlock Text="{x:Static local:Localization.LabelTeklaTextLayer}" Margin="18,4,4,0" />
                        <ComboBox x:Name="TeklaTextLayerComboBox" Width="150" />
                        <TextBlock Text="{x:Static local:Localization.LabelFormatLayer}" Margin="18,4,4,0" />
                        <ComboBox x:Name="FormatBlockLayerComboBox" Width="150" />
                    </StackPanel>
                    <DataGrid x:Name="LayerRulesGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended" MouseDoubleClick="LayerRulesGridDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerBase}" Binding="{Binding BaseLayer}" Width="220" />
                            <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerFilter}" Binding="{Binding Filter}" Width="320" />
                            <DataGridTextColumn Header="{x:Static local:Localization.LabelNewLayer}" Binding="{Binding NewLayer}" Width="320" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabDimensions}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <UniformGrid Columns="4">
                            <TextBlock Text="{x:Static local:Localization.LabelLayer}" />
                            <ComboBox x:Name="DimensionLayerComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelLineColor}" />
                            <ComboBox x:Name="DimensionLineColorComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelTextColor}" />
                            <ComboBox x:Name="DimensionTextColorComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelArrowType}" />
                            <ComboBox x:Name="DimensionArrowTypeComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimStyle}" />
                            <TextBox x:Name="DimensionStyleTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelTextStyle}" />
                            <ComboBox x:Name="TextStyleComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionScale}" />
                            <TextBox x:Name="DimensionScaleTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionArrowSize}" />
                            <TextBox x:Name="DimensionArrowSizeTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionOffset}" />
                            <TextBox x:Name="DimensionOffsetTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionLineExtend}" />
                            <TextBox x:Name="DimensionLineExtTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionLinearPrecision}" />
                            <ComboBox x:Name="DimensionLinearPrecisionComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionAngularPrecision}" />
                            <ComboBox x:Name="DimensionAngularPrecisionComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionLinearUnit}" />
                            <ComboBox x:Name="DimensionLinearUnitComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionAngularUnit}" />
                            <ComboBox x:Name="DimensionAngularUnitComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionOutsideAlign}" />
                            <ComboBox x:Name="DimensionOutsideAlignComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionLineForced}" />
                            <ComboBox x:Name="DimensionLineForcedComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionTextInside}" />
                            <ComboBox x:Name="DimensionTextInsideComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionTextAlignment}" />
                            <ComboBox x:Name="DimensionTextAlignmentComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionTextPlacementVertical}" />
                            <ComboBox x:Name="DimensionTextPlacementComboBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelDimensionBaseLayer}" />
                            <ComboBox x:Name="DimensionBaseLayerComboBox" IsEditable="True" />
                        </UniformGrid>
                        <Button Content="{x:Static local:Localization.LabelDimensionArrowSettingsButton}" Width="260" Margin="0,12,0,0" Click="DimensionArrowAdvancedClick" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabScale}">
                <StackPanel Margin="10">
                    <RadioButton x:Name="ManualScaleRadio" Content="{x:Static local:Localization.LabelManualScale}" Checked="ScaleModeChanged" />
                    <RadioButton x:Name="AutoScaleRadio" Content="{x:Static local:Localization.LabelAutomaticScale}" Checked="ScaleModeChanged" />
                    <GroupBox Header="{x:Static local:Localization.LabelManual}" Margin="0,10,0,0">
                        <UniformGrid Columns="6">
                            <TextBlock Text="{x:Static local:Localization.LabelP1X}" />
                            <TextBox x:Name="P1XTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP1Y}" />
                            <TextBox x:Name="P1YTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP1Z}" />
                            <TextBox x:Name="P1ZTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2X}" />
                            <TextBox x:Name="P2XTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2Y}" />
                            <TextBox x:Name="P2YTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2Z}" />
                            <TextBox x:Name="P2ZTextBox" />
                        </UniformGrid>
                    </GroupBox>
                    <GroupBox Header="{x:Static local:Localization.LabelAutomatic}" Margin="0,10,0,0">
                        <UniformGrid Columns="6">
                            <TextBlock Text="{x:Static local:Localization.LabelP1X}" />
                            <TextBox x:Name="AP1XTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP1Y}" />
                            <TextBox x:Name="AP1YTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP1Z}" />
                            <TextBox x:Name="AP1ZTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2X}" />
                            <TextBox x:Name="AP2XTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2Y}" />
                            <TextBox x:Name="AP2YTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelP2Z}" />
                            <TextBox x:Name="AP2ZTextBox" />
                            <TextBlock Text="{x:Static local:Localization.LabelTextLayer}" />
                            <ComboBox x:Name="ZoomLayerFilterComboBox" IsEditable="True" />
                            <TextBlock Text="{x:Static local:Localization.LabelTextSize}" />
                            <TextBox x:Name="ZoomTextSizeTextBox" />
                        </UniformGrid>
                    </GroupBox>
                </StackPanel>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabRemoveLayers}">
                <DockPanel Margin="10">
                    <StackPanel DockPanel.Dock="Left" Width="230" Margin="0,0,10,0">
                        <TextBlock Text="{x:Static local:Localization.LabelLayersAfterConversion}" />
                        <ListBox x:Name="RemoveLayerBaseListBox" Height="320" />
                        <Button Content="{x:Static local:Localization.ButtonAdd}" Margin="0,8,0,0" Click="AddRemoveLayerClick" />
                        <Button Content="{x:Static local:Localization.ButtonRemove}" Margin="0,6,0,0" Click="DeleteRemoveLayerClick" />
                    </StackPanel>
                    <DataGrid x:Name="RemoveLayersGrid" AutoGenerateColumns="False" CanUserAddRows="False" MouseDoubleClick="RemoveLayersGridDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="{x:Static local:Localization.LabelLayer}" Binding="{Binding Layer}" Width="220" />
                            <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerFilter}" Binding="{Binding Filter}" Width="360" />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabBlocksAndAttributes}">
                <TabControl Margin="10">
                    <TabItem Header="{x:Static local:Localization.TabTeklaStructures}">
                        <DockPanel Margin="8">
                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
                                <TextBox x:Name="AttributedFormatPathTextBox" Width="520" />
                                <Button Content="{x:Static local:Localization.ButtonAttributedFormat}" Margin="6,0,0,0" Click="BrowseAttributedFormatClick" />
                            </StackPanel>
                            <ListBox x:Name="BlocksListBox" Margin="0,8,0,0" />
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="{x:Static local:Localization.ButtonEdit}" Click="EditBlockClick" />
                                <Button Content="{x:Static local:Localization.ButtonRemove}" Margin="6,0,0,0" Click="RemoveBlockClick" />
                            </StackPanel>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="{x:Static local:Localization.TabCad}">
                        <Grid Margin="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition />
                                <ColumnDefinition />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="{x:Static local:Localization.LabelCad}" />
                                <ListBox x:Name="InventorBlocksListBox" Height="320" />
                                <Button Content="{x:Static local:Localization.ButtonLoadCadBlocks}" Click="LoadInventorBlocksClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0">
                                <TextBlock Text="{x:Static local:Localization.LabelOriginalBlocks}" />
                                <ListBox x:Name="OriginalBlocksListBox" Height="320" />
                                <Button Content="{x:Static local:Localization.ButtonLoadOriginalBlocks}" Click="LoadOriginalBlocksClick" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{x:Static local:Localization.LabelRelations}" />
                                <ListBox x:Name="BlockRelationsListBox" Height="320" MouseDoubleClick="BlockRelationsDoubleClick" />
                                <Button Content="{x:Static local:Localization.ButtonRelate}" Click="RelateBlocksClick" />
                                <Button Content="{x:Static local:Localization.ButtonEditRelationParameters}" Margin="0,6,0,0" Click="EditBlockRelationClick" />
                                <Button Content="{x:Static local:Localization.ButtonRemoveRelation}" Margin="0,6,0,0" Click="RemoveBlockRelationClick" />
                            </StackPanel>
                        </Grid>
                    </TabItem>
                </TabControl>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabConfigurationLispDll}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <GroupBox Header="{x:Static local:Localization.LabelLisp}" Margin="0,0,5,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBox x:Name="LispCommandTextBox" />
                                <TextBox x:Name="LispPathTextBox" Margin="0,4,0,0" />
                                <CheckBox x:Name="RunOnlyAtEndCheckBox" Content="{x:Static local:Localization.LabelRunOnlyAtEnd}" />
                                <Button Content="{x:Static local:Localization.ButtonAdd}" Click="AddLispClick" />
                            </StackPanel>
                            <ListBox x:Name="LispListBox" />
                        </DockPanel>
                    </GroupBox>
                    <GroupBox Grid.Column="1" Header="{x:Static local:Localization.LabelDll}" Margin="5,0,0,0">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top">
                                <TextBox x:Name="DllCommandTextBox" />
                                <TextBox x:Name="DllPathTextBox" Margin="0,4,0,0" />
                                <Button Content="{x:Static local:Localization.ButtonSave}" Click="AddDllClick" />
                            </StackPanel>
                            <ListBox x:Name="DllListBox" />
                        </DockPanel>
                    </GroupBox>
                </Grid>
            </TabItem>
            <TabItem Header="{x:Static local:Localization.TabExplosionOfBlocks}">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="{x:Static local:Localization.LabelAllLayers}" />
                        <ListBox x:Name="AllExplodeLayersListBox" Height="420" />
                        <Button Content="{x:Static local:Localization.ButtonAdd}" Click="AddExplodeLayerClick" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                        <TextBlock Text="{x:Static local:Localization.LabelExplodeOnlyLayers}" />
                        <ListBox x:Name="SelectedExplodeLayersListBox" Height="420" />
                        <Button Content="{x:Static local:Localization.ButtonRemove}" Click="RemoveExplodeLayerClick" />
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
