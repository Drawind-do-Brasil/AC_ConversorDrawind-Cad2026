<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorScaleTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <StackPanel Margin="10">
        <RadioButton x:Name="ManualScaleRadio" Content="{x:Static local:Localization.LabelManualScale}" Checked="ScaleModeChanged" />
        <RadioButton x:Name="AutoScaleRadio" Content="{x:Static local:Localization.LabelAutomaticScale}" Checked="ScaleModeChanged" />
        <GroupBox Header="{x:Static local:Localization.LabelManual}" Margin="0,10,0,0">
            <UniformGrid Columns="6">
                <TextBlock Text="{x:Static local:Localization.LabelP1X}" />
                <TextBox x:Name="P1XTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP1Y}" />
                <TextBox x:Name="P1YTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP1Z}" />
                <TextBox x:Name="P1ZTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2X}" />
                <TextBox x:Name="P2XTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2Y}" />
                <TextBox x:Name="P2YTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2Z}" />
                <TextBox x:Name="P2ZTextBox" />
            </UniformGrid>
        </GroupBox>
        <GroupBox Header="{x:Static local:Localization.LabelAutomatic}" Margin="0,10,0,0">
            <UniformGrid Columns="6">
                <TextBlock Text="{x:Static local:Localization.LabelP1X}" />
                <TextBox x:Name="AP1XTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP1Y}" />
                <TextBox x:Name="AP1YTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP1Z}" />
                <TextBox x:Name="AP1ZTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2X}" />
                <TextBox x:Name="AP2XTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2Y}" />
                <TextBox x:Name="AP2YTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelP2Z}" />
                <TextBox x:Name="AP2ZTextBox" />
                <TextBlock Text="{x:Static local:Localization.LabelTextLayer}" />
                <ComboBox x:Name="ZoomLayerFilterComboBox" IsEditable="True" />
                <TextBlock Text="{x:Static local:Localization.LabelTextSize}" />
                <TextBox x:Name="ZoomTextSizeTextBox" />
            </UniformGrid>
        </GroupBox>
    </StackPanel>
</UserControl>
