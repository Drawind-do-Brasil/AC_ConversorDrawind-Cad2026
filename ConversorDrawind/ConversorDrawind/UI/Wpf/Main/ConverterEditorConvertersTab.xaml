<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorConvertersTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="{x:Static local:Localization.ButtonAdd}" Width="110" Click="AddLayerRuleClick" />
            <Button Content="{x:Static local:Localization.ButtonDelete}" Width="110" Margin="6,0,0,0" Click="DeleteLayerRuleClick" />
            <Button Content="{x:Static local:Localization.ButtonMoveUp}" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleUpClick" />
            <Button Content="{x:Static local:Localization.ButtonMoveDown}" Width="120" Margin="6,0,0,0" Click="MoveLayerRuleDownClick" />
    
        </StackPanel>
        <DataGrid x:Name="LayerRulesGrid" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Extended" MouseDoubleClick="LayerRulesGridDoubleClick">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerBase}" Binding="{Binding BaseLayer}" Width="220" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelLayerFilter}" Binding="{Binding Filter}" Width="320" />
                <DataGridTextColumn Header="{x:Static local:Localization.LabelNewLayer}" Binding="{Binding NewLayer}" Width="320" />
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel  DockPanel.Dock="Bottom">
            <TextBlock Text="{x:Static local:Localization.LabelLtScale}" Margin="18,4,4,0" />
            <TextBox x:Name="LtScaleTextBox" Width="70" />
            <TextBlock Text="{x:Static local:Localization.LabelTeklaTextLayer}" Margin="18,4,4,0" />
            <ComboBox x:Name="TeklaTextLayerComboBox" Width="150" />
            <TextBlock Text="{x:Static local:Localization.LabelFormatLayer}" Margin="18,4,4,0" />
            <ComboBox x:Name="FormatBlockLayerComboBox" Width="150" />
        </StackPanel>
    </DockPanel>
</UserControl>
