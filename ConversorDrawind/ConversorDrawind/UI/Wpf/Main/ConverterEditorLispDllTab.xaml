<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorLispDllTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="LispListBox"
                 Grid.Row="0"
                 HorizontalContentAlignment="Stretch"
                 SelectionChanged="LispListBoxSelectionChanged"
                 MouseDoubleClick="LispListBoxDoubleClick">
            <ListBox.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="{x:Static local:Localization.ButtonAdd}" Click="AddLispClick" />
                    <MenuItem Header="{x:Static local:Localization.ButtonModify}" Click="ModifyLispClick" />
                    <MenuItem Header="{x:Static local:Localization.ButtonDelete}" Click="DeleteLispClick" />
                    <Separator />
                    <MenuItem Header="{x:Static local:Localization.ButtonMoveUp}" Click="MoveLispUpClick" />
                    <MenuItem Header="{x:Static local:Localization.ButtonMoveDown}" Click="MoveLispDownClick" />
                </ContextMenu>
            </ListBox.ContextMenu>
        </ListBox>

        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    Margin="0,8,0,0">
            <Button Width="132"
                    Margin="0,0,8,0"
                    Content="{x:Static local:Localization.ButtonAdd}"
                    Click="AddLispClick" />
            <Button Width="132"
                    Margin="0,0,8,0"
                    Content="{x:Static local:Localization.ButtonModify}"
                    Click="ModifyLispClick" />
            <Button Width="132"
                    Margin="0,0,8,0"
                    Content="{x:Static local:Localization.ButtonDelete}"
                    Click="DeleteLispClick" />
            <Button Width="110"
                    Margin="0,0,8,0"
                    Content="{x:Static local:Localization.ButtonMoveUp}"
                    Click="MoveLispUpClick" />
            <Button Width="120"
                    Content="{x:Static local:Localization.ButtonMoveDown}"
                    Click="MoveLispDownClick" />
        </StackPanel>
    </Grid>
</UserControl>
