<UserControl x:Class="ConversorDrawind.UI.Wpf.Main.ConverterEditorLispDllTab"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:ConversorDrawind">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ListBox x:Name="LispListBox"
                 Grid.Row="0"
                 HorizontalContentAlignment="Stretch"
                 SelectionChanged="LispListBoxSelectionChanged" />

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="42" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{x:Static local:Localization.LabelCommandName}" />
            <TextBox x:Name="LispCommandTextBox"
                     Grid.Row="0"
                     Grid.Column="2"
                     MinWidth="300"
                     HorizontalAlignment="Stretch" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,8,8,0"
                       Text="{x:Static local:Localization.LabelCommandPath}" />
            <Button Grid.Row="1"
                    Grid.Column="1"
                    Width="38"
                    Height="23"
                    Margin="0,8,4,0"
                    Content="{x:Static local:Localization.ButtonEllipsis}"
                    Click="BrowseLispPathClick" />
            <TextBox x:Name="LispPathTextBox"
                     Grid.Row="1"
                     Grid.Column="2"
                     Margin="0,8,0,0"
                     HorizontalAlignment="Stretch" />

            <Grid Grid.Row="2"
                  Grid.Column="0"
                  Grid.ColumnSpan="3"
                  Margin="0,10,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Width="132"
                        Height="26"
                        Margin="0,0,8,0"
                        HorizontalAlignment="Left"
                        Content="{x:Static local:Localization.ButtonAdd}"
                        Click="AddLispClick" />
                <Button Grid.Column="1"
                        Width="78"
                        Height="26"
                        Margin="0,0,6,0"
                        Content="&lt;&lt;"
                        Click="MoveLispUpClick" />
                <Button Grid.Column="2"
                        Width="78"
                        Height="26"
                        Content="&gt;&gt;"
                        Click="MoveLispDownClick" />
                <CheckBox x:Name="RunOnlyAtEndCheckBox"
                          Grid.Column="3"
                          HorizontalAlignment="Right"
                          VerticalAlignment="Center"
                          Margin="18,4,0,0"
                          Content="{x:Static local:Localization.LabelRunOnlyAtEnd}" />
            </Grid>

            <StackPanel Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Vertical"
                        Margin="0,8,0,0">
                <Button Width="132"
                        Height="26"
                        Margin="0,0,0,6"
                        HorizontalAlignment="Left"
                        Content="{x:Static local:Localization.ButtonModify}"
                        Click="ModifyLispClick" />
                <Button Width="132"
                        Height="26"
                        HorizontalAlignment="Left"
                        Content="{x:Static local:Localization.ButtonDelete}"
                        Click="DeleteLispClick" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
