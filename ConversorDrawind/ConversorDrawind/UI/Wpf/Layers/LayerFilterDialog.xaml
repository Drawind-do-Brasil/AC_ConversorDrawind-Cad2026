<Window x:Class="ConversorDrawind.UI.Wpf.Layers.LayerFilterDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TitleFilter}"
        Width="320"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="12">
        <StackPanel>
            <GroupBox x:Name="ObjectTypeGroupBox" Header="{x:Static local:Localization.LabelObjectType}" Margin="0,0,0,8">
                <StackPanel Margin="6">
                    <ComboBox x:Name="ObjectTypeComboBox" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,6" />
                    <Button Content="{x:Static local:Localization.ButtonAddOtherEntities}" Click="AddEntityButtonClick" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="{x:Static local:Localization.LabelColor}" Margin="0,0,0,8">
                <StackPanel Margin="6">
                    <ComboBox x:Name="ColorComboBox" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,6" />
                    <Button Content="{x:Static local:Localization.ButtonOtherColorTypes}" Click="OtherColorButtonClick" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="LineTypeGroupBox" Header="{x:Static local:Localization.LabelLineType}" Margin="0,0,0,8">
                <StackPanel Margin="6">
                    <ComboBox x:Name="LineTypeComboBox" IsEditable="True" IsTextSearchEnabled="True" Margin="0,0,0,6" />
                    <Button Content="{x:Static local:Localization.ButtonLoadLineTypes}" Click="LoadLineTypesButtonClick" />
                </StackPanel>
            </GroupBox>

            <GroupBox x:Name="TextGroupBox" Header="{x:Static local:Localization.LabelText}" Margin="0,0,0,8">
                <Grid Margin="6">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{x:Static local:Localization.LabelContent}" VerticalAlignment="Center" Margin="0,0,8,6" />
                    <TextBox x:Name="TextContentTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,6" />

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{x:Static local:Localization.LabelHeight}" VerticalAlignment="Center" Margin="0,0,8,0" />
                    <TextBox x:Name="TextHeightTextBox" Grid.Row="1" Grid.Column="1" PreviewTextInput="DecimalTextBoxPreviewTextInput" />
                </Grid>
            </GroupBox>

            <GroupBox x:Name="OrientationGroupBox" Header="{x:Static local:Localization.LabelOrientation}" Margin="0,0,0,16">
                <ComboBox x:Name="OrientationComboBox"
                          Margin="6"
                          IsEditable="False"
                          SelectionChanged="OrientationComboBoxSelectionChanged" />
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{x:Static local:Localization.ButtonContinue}" IsDefault="True" MinWidth="96" Margin="0,0,8,0" Click="ContinueButtonClick" />
                <Button Content="{x:Static local:Localization.ButtonCancel}" IsCancel="True" MinWidth="96" Click="CancelButtonClick" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
