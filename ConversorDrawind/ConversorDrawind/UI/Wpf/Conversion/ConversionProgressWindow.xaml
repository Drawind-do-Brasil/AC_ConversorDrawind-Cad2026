<Window x:Class="ConversorDrawind.UI.Wpf.Conversion.ConversionProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Processando"
        Width="544"
        Height="320"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
        Opacity="0.7"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <TextBlock HorizontalAlignment="Center"
                   Margin="0,10,0,0"
                   FontSize="34"
                   FontWeight="SemiBold"
                   Foreground="#333333"
                   Text="DRAWIND" />

        <TextBlock x:Name="StatusTextBlock"
                   HorizontalAlignment="Center"
                   Margin="0,127,0,0"
                   FontSize="42"
                   Foreground="#696969"
                   Text="Convertendo" />

        <ProgressBar x:Name="ProgressBar"
                     Height="34"
                     Margin="0,179,0,0"
                     VerticalAlignment="Top"
                     Minimum="0"
                     Maximum="100" />

        <TextBlock x:Name="RemainingTimeTextBlock"
                   Margin="235,220,0,0"
                   VerticalAlignment="Top"
                   Text="..." />

        <TextBlock x:Name="ElapsedTimeTextBlock"
                   Margin="0,220,0,0"
                   VerticalAlignment="Top"
                   Text="..." />

        <TextBlock x:Name="ProcessTextBlock"
                   Margin="0,243,0,0"
                   VerticalAlignment="Top"
                   Text="Iniciando o Autocad 2026..." />

        <TextBlock x:Name="VersionTextBlock"
                   Margin="0,290,0,0"
                   VerticalAlignment="Top"
                   Foreground="Blue" />

        <Button x:Name="CancelButton"
                Content="Cancelar"
                Width="112"
                Height="31"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsEnabled="False"
                Click="CancelClick" />
    </Grid>
</Window>
