<Window x:Class="ConversorDrawind.UI.Wpf.Conversion.ConversionProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TitleProcessing}"
        Width="544"
        Height="367"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Topmost="True"
  
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Image HorizontalAlignment="Center"
               Margin="0,10,0,0"
               VerticalAlignment="Top"
               Width="260"
               Source="pack://application:,,,/Resources/DRAWIND_PEQUENA.png" />

        <TextBlock x:Name="StatusTextBlock"
                   HorizontalAlignment="Center"
                   Margin="0,127,0,0"
                   Width="310"
                   FontSize="42"
                   Foreground="#696969"
                   TextAlignment="Left"
                   Text="{x:Static local:Localization.LabelConverting}" />

        <ProgressBar x:Name="ProgressBar"
                     Height="34"
                     Margin="0,179,0,0"
                     VerticalAlignment="Top"
                     Minimum="0"
                     Maximum="100" />

        <TextBlock x:Name="RemainingTimeTextBlock"
                   Margin="235,220,0,0"
                   VerticalAlignment="Top"
                   Text="{x:Static local:Localization.LabelLoadingDots}" />

        <TextBlock x:Name="ElapsedTimeTextBlock"
                   Margin="0,220,0,0"
                   VerticalAlignment="Top"
                   Text="{x:Static local:Localization.LabelLoadingDots}" />

        <TextBlock x:Name="ProcessTextBlock"
                   Margin="0,243,0,0"
                   VerticalAlignment="Top"
                   Text="{x:Static local:Localization.LabelStartedAutoCad2026}" />

        <TextBlock x:Name="VersionTextBlock"
                   Margin="0,264,0,0"
                   VerticalAlignment="Top"
                   Foreground="Blue" />

        <Button x:Name="CancelButton"
                Content="{x:Static local:Localization.ButtonCancel}"
                Width="112"
                Height="31"
                HorizontalAlignment="Right"
                VerticalAlignment="Bottom"
                IsEnabled="False"
                Click="CancelClick" />
    </Grid>
</Window>
