<Window x:Class="ConversorDrawind.UI.Wpf.Conversion.ConversionFinishedDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Width="545"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="120" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="{x:Static local:Localization.LabelDrawind}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="34"
                   FontWeight="Bold" />

        <TextBlock Grid.Row="1"
                   Text="{x:Static local:Localization.LabelFinished}"
                   HorizontalAlignment="Center"
                   Foreground="DimGray"
                   FontSize="42" />

        <TextBlock x:Name="ProcessTimeTextBlock"
                   Grid.Row="2"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20" />

        <Button Grid.Row="4"
                Content="{x:Static local:Localization.ButtonOk}"
                Width="162"
                Height="28"
                HorizontalAlignment="Center"
                IsDefault="True"
                IsCancel="True"
                Click="OkButtonClick" />
    </Grid>
</Window>
