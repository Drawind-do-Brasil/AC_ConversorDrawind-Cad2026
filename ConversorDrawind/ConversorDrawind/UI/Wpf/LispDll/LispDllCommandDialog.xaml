<Window x:Class="ConversorDrawind.UI.Wpf.LispDll.LispDllCommandDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ConversorDrawind"
        Title="{x:Static local:Localization.TabConfigurationLispDll}"
        Width="650"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False">
    <Border Padding="16">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="145" />
                <ColumnDefinition Width="42" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Text="{x:Static local:Localization.LabelCommandName}" />
            <TextBox x:Name="CommandNameTextBox"
                     Grid.Row="0"
                     Grid.Column="2" />

            <TextBlock Grid.Row="1"
                       Grid.Column="0"
                       VerticalAlignment="Center"
                       Margin="0,8,8,0"
                       Text="{x:Static local:Localization.LabelCommandPath}" />
            <Button Grid.Row="1"
                    Grid.Column="1"
                    Width="38"
                    Margin="0,8,4,0"
                    Content="{x:Static local:Localization.ButtonEllipsis}"
                    Click="BrowseButtonClick" />
            <TextBox x:Name="CommandPathTextBox"
                     Grid.Row="1"
                     Grid.Column="2"
                     Margin="0,8,0,0" />

            <CheckBox x:Name="RunOnlyAtEndCheckBox"
                      Grid.Row="2"
                      Grid.Column="0"
                      Grid.ColumnSpan="3"
                      Margin="0,12,0,0"
                      Content="{x:Static local:Localization.LabelRunOnlyAtEnd}" />

            <StackPanel Grid.Row="3"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="{x:Static local:Localization.ButtonContinue}"
                        MinWidth="96"
                        Margin="0,0,8,0"
                        IsDefault="True"
                        Click="ContinueButtonClick" />
                <Button Content="{x:Static local:Localization.ButtonCancel}"
                        MinWidth="96"
                        IsCancel="True"
                        Click="CancelButtonClick" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
